# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_NAME="OkaCRM"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# -----------------------------------------------------------------------------
# Database
# Use mysql or pgsql for deployed environments.
# -----------------------------------------------------------------------------
DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

# -----------------------------------------------------------------------------
# Session
# For production deployments, use SESSION_DRIVER=redis.
# -----------------------------------------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# -----------------------------------------------------------------------------
# Broadcasting / Files / Queue / Cache
# For production deployments, use QUEUE_CONNECTION=redis.
# -----------------------------------------------------------------------------
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
MEMCACHED_HOST=127.0.0.1
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# Mail
# -----------------------------------------------------------------------------
MAIL_MAILER=postmark
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
POSTMARK_API_KEY=
HORIZON_WAITS_NOTIFICATION_EMAIL=

# -----------------------------------------------------------------------------
# AWS / Storage
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
VITE_APP_NAME="${APP_NAME}"

# -----------------------------------------------------------------------------
# PDF Generation (Puppeteer / Chrome)
# -----------------------------------------------------------------------------
PUPPETEER_NODE_BINARY=
PUPPETEER_NPM_BINARY=
PUPPETEER_CHROME_PATH=
PUPPETEER_NO_SANDBOX=true
PUPPETEER_TIMEOUT=60

# -----------------------------------------------------------------------------
# Instagram OAuth
# -----------------------------------------------------------------------------
META_CLIENT_ID=
META_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# TikTok OAuth
# -----------------------------------------------------------------------------
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=https://influence-me.test/auth/tiktok/callback

# -----------------------------------------------------------------------------
# Twitch OAuth
# -----------------------------------------------------------------------------
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Stripe
# -----------------------------------------------------------------------------
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
